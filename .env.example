# ── Google AI (Gemini + Imagen 3) ─────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Meta WhatsApp Cloud API ────────────────────────────────────────────────────
# Permanent access token from your Meta App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_permanent_token_here

# Phone Number ID (not the phone number itself) — from Meta App → WhatsApp → API Setup
WHATSAPP_PHONE_ID=your_phone_number_id_here

# Any random secret string — you'll paste this into Meta's webhook config
WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token_123

# Port — Railway sets this automatically, leave as 3000 for local testing
PORT=3000